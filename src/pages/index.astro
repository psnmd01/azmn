---
import '../styles/global.css';
import copy from '../content/copy.en.json';

const navItems = [
  { href: '#how-it-works', label: copy.nav.link_how_it_works, key: 'nav.link_how_it_works' },
  { href: '#features', label: copy.nav.link_features, key: 'nav.link_features' },
  { href: '#pricing', label: copy.nav.link_pricing, key: 'nav.link_pricing' },
  { href: '#faq', label: copy.nav.link_faq, key: 'nav.link_faq' },
];

const footerGroups = [
  {
    key: 'product',
    heading: copy.footer.secondary_nav.product.heading,
    links: navItems.map((item) => ({ href: item.href, label: item.label, key: item.key })),
  },
];

const steps = [
  {
    title: copy.how_it_works.step_1_title,
    body: copy.how_it_works.step_1_desc,
    titleKey: 'how_it_works.step_1_title',
    bodyKey: 'how_it_works.step_1_desc',
  },
  {
    title: copy.how_it_works.step_2_title,
    body: copy.how_it_works.step_2_desc,
    titleKey: 'how_it_works.step_2_title',
    bodyKey: 'how_it_works.step_2_desc',
  },
  {
    title: copy.how_it_works.step_3_title,
    body: copy.how_it_works.step_3_desc,
    titleKey: 'how_it_works.step_3_title',
    bodyKey: 'how_it_works.step_3_desc',
  },
];

const featureCardSpans = ['lg:col-span-4', 'lg:col-span-3', 'lg:col-span-3', 'lg:col-span-5', 'lg:col-span-5'];

const orchestrationSteps = copy.orchestration.steps.map((step, index) => ({
  ...step,
  index,
  number: String(index + 1).padStart(2, '0'),
}));

const basePath = import.meta.env.BASE_URL.replace(/\/$/, '');
const assetUrl = (path: string) => `${basePath}${path}`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta
      name="description"
      content="Azaman spins up autonomous AI-agent companies that plan, build, review, and ship real software over Discord with human approval gates."
    />
    <link rel="preload" href={assetUrl('/fonts/fraunces-latin-standard-normal.woff2')} as="font" type="font/woff2" crossorigin />
    <link rel="icon" href={assetUrl('/favicon.svg')} type="image/svg+xml" />
    <title>Azaman | Autonomous AI-agent companies</title>
  </head>
  <body class="bg-surface text-ink">
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:fixed focus:left-5 focus:top-5 focus:z-50 focus:rounded-card focus:bg-surface-raised focus:px-4 focus:py-3 focus:text-body-sm focus:text-ink focus:shadow-lift"
      >Skip to content</a
    >

    <header class="sticky top-0 z-40 border-b border-border bg-surface-raised/90 shadow-nav backdrop-blur">
      <nav class="container-page flex min-h-16 items-center justify-between gap-4 md:min-h-[72px]" aria-label="Primary navigation">
        <a href="#main" class="flex items-center gap-3 text-body font-bold text-ink" aria-label={copy.nav.brand} data-i18n="nav.brand">
          <span class="grid size-8 place-items-center rounded-card bg-accent text-caption text-accent-on" aria-hidden="true">A</span>
          <span>{copy.nav.brand}</span>
        </a>
        <div class="hidden items-center gap-7 md:flex">
          {
            navItems.map((item) => (
              <a href={item.href} class="text-body-sm text-ink-muted transition duration-200 ease-expressive hover:text-ink" data-i18n={item.key}>
                {item.label}
              </a>
            ))
          }
        </div>
        <a href="#pricing" class="button button-primary" data-i18n="nav.cta">{copy.nav.cta}</a>
      </nav>
    </header>

    <main id="main">
      <section class="hero-section relative isolate overflow-hidden bg-ink text-white">
        <div class="hero-mesh" aria-hidden="true">
          <span class="hero-mesh__field hero-mesh__field--one" data-mesh-layer="one"></span>
          <span class="hero-mesh__field hero-mesh__field--two" data-mesh-layer="two"></span>
          <span class="hero-mesh__field hero-mesh__field--three" data-mesh-layer="three"></span>
          <span class="hero-mesh__field hero-mesh__field--four" data-mesh-layer="four"></span>
          <span class="hero-mesh__field hero-mesh__field--five" data-mesh-layer="five"></span>
        </div>
        <div class="container-page relative z-10 grid min-h-[calc(100svh-4rem)] gap-10 py-14 sm:py-16 lg:grid-cols-[0.88fr_1.12fr] lg:items-center lg:py-20 xl:gap-hero-gap">
          <div data-reveal>
            <p class="eyebrow text-accent-soft" data-i18n="hero.badge">{copy.hero.badge}</p>
            <h1 class="mt-5 max-w-3xl font-display text-h2 text-white sm:text-h1 xl:text-display" data-i18n="hero.headline" data-split-title>
              {copy.hero.headline}
            </h1>
            <p class="mt-6 max-w-2xl text-body text-[color:var(--color-footer-muted)] sm:text-body-lg" data-i18n="hero.sub">
              {copy.hero.sub}
            </p>
            <div class="mt-8 flex flex-col gap-4 sm:flex-row sm:items-center">
              <a href="#pricing" class="button button-primary min-h-[52px] px-6" data-i18n="hero.cta_primary">{copy.hero.cta_primary}</a>
              <a
                href="#how-it-works"
                class="inline-flex min-h-11 items-center text-body-sm font-bold text-accent-soft underline-offset-4 transition hover:text-white hover:underline"
                data-i18n="hero.cta_secondary"
                >{copy.hero.cta_secondary}</a
              >
            </div>
            <ul class="mt-8 grid gap-3 sm:grid-cols-3" aria-label={copy.hero.proof_label}>
              {
                copy.hero.proof_points.map((point, index) => (
                  <li class="rounded-card border border-white/10 bg-white/[0.055] p-4 backdrop-blur">
                    <p class="font-mono text-caption text-accent-soft" data-i18n={`hero.proof_points.${index}.kicker`}>{point.kicker}</p>
                    <p class="mt-2 text-body-sm font-bold text-white" data-i18n={`hero.proof_points.${index}.label`}>{point.label}</p>
                  </li>
                ))
              }
            </ul>
          </div>

          <aside class="generative-stage" aria-label={copy.hero.visual_alt} data-reveal>
            <div class="stage-chrome">
              <div class="flex items-start justify-between gap-4 border-b border-white/10 pb-4">
                <div>
                  <p class="font-mono text-caption uppercase text-[#d8d2c7]" data-i18n="hero.stage_title">{copy.hero.stage_title}</p>
                  <p class="mt-1 font-display text-h4 text-white" data-i18n="hero.headline">{copy.hero.headline}</p>
                </div>
                <span class="rounded-control border border-accent bg-accent px-3 py-2 font-mono text-caption text-accent-on" data-i18n="hero.stage_status">
                  {copy.hero.stage_status}
                </span>
              </div>

              <div class="crew-artifact mt-5" data-signature-motion>
                <svg class="crew-artifact__lines" viewBox="0 0 620 420" role="img" aria-label="A gated build moving from brief to crew lanes to review and ship">
                  <defs>
                    <linearGradient id="crew-line-gradient" x1="0" x2="1" y1="0" y2="1">
                      <stop offset="0" stop-color="#bc2a64"></stop>
                      <stop offset="0.52" stop-color="#e0457b"></stop>
                      <stop offset="1" stop-color="#fce7ef"></stop>
                    </linearGradient>
                  </defs>
                  <path data-flow-line d="M72 212 C154 88 244 82 314 156 S445 280 548 170" fill="none" stroke="url(#crew-line-gradient)" stroke-width="2.5" stroke-linecap="round"></path>
                  <path d="M86 304 C186 248 262 316 338 248 S470 100 544 244" fill="none" stroke="rgba(255,255,255,.16)" stroke-width="1.5" stroke-dasharray="7 12"></path>
                </svg>

                <div class="artifact-node artifact-node--brief" data-agent-node>
                  <p class="font-mono text-caption text-accent-soft" data-i18n="hero.stage_brief">{copy.hero.stage_brief}</p>
                  <p class="mt-2 text-h4 text-white" data-i18n="hero.stage_brief_detail">{copy.hero.stage_brief_detail}</p>
                </div>

                <div class="artifact-node artifact-node--crew" data-agent-node>
                  <p class="font-mono text-caption text-[#d8d2c7]" data-i18n="hero.stage_agents">{copy.hero.stage_agents}</p>
                  <ul class="mt-3 grid grid-cols-2 gap-2">
                    {
                      copy.hero.stage_agent_lanes.map((lane, index) => (
                        <li class={`rounded-card border border-white/10 bg-white/[0.07] p-2.5 ${index === 4 ? 'col-span-2' : ''}`}>
                          <p class="flex items-center gap-2 font-mono text-caption font-bold text-white">
                            <span class="text-accent-soft">{String(index + 1).padStart(2, '0')}</span>
                            <span data-i18n={`hero.stage_agent_lanes.${index}`}>{lane}</span>
                          </p>
                        </li>
                      ))
                    }
                  </ul>
                </div>

                <div class="artifact-node artifact-node--gate" data-agent-node>
                  <p class="font-mono text-caption text-accent-soft" data-i18n="hero.stage_gate">{copy.hero.stage_gate}</p>
                  <p class="mt-2 text-h4 text-white" data-i18n="features.cards.2.title">{copy.features.cards[2].title}</p>
                </div>

                <div class="artifact-node artifact-node--ship" data-agent-node>
                  <p class="font-mono text-caption text-[#d8d2c7]" data-i18n="hero.stage_ship">{copy.hero.stage_ship}</p>
                  <p class="mt-2 text-h4 text-white" data-i18n="hero.stage_ship_detail">{copy.hero.stage_ship_detail}</p>
                </div>
              </div>
            </div>
          </aside>
        </div>
      </section>

      <section id="how-it-works" class="orchestration-section border-b border-border bg-surface-raised py-section lg:py-section-lg">
        <div class="container-page grid gap-12 lg:grid-cols-[0.76fr_1.24fr] lg:items-start">
          <div class="lg:sticky lg:top-28" data-reveal>
            <p class="eyebrow" data-i18n="how_it_works.section_title">{copy.how_it_works.section_title}</p>
            <h2 class="section-heading font-display" data-i18n="how_it_works.section_subtitle">{copy.how_it_works.section_subtitle}</h2>
            <p class="section-copy" data-i18n="how_it_works.intro">{copy.how_it_works.intro}</p>
            <div class="manifesto-band mt-8">
              <p class="font-display text-h3 text-ink" data-i18n="orchestration.manifesto">{copy.orchestration.manifesto}</p>
            </div>
          </div>

          <div class="orchestration-scroll" data-orchestration data-reveal>
            <div class="orchestration-track" aria-hidden="true">
              <span data-orch-line></span>
            </div>
            <ol class="grid gap-5" aria-label={copy.orchestration.label}>
              {
                orchestrationSteps.map((step) => (
                  <li class={`orchestration-card ${step.index % 2 === 1 ? 'lg:ml-16' : ''}`} data-orch-card>
                    <div class="grid gap-4 sm:grid-cols-[auto_1fr]">
                      <span class="grid size-12 place-items-center rounded-control bg-accent font-mono text-body-sm font-bold text-accent-on">
                        {step.number}
                      </span>
                      <div>
                        <p class="font-mono text-caption uppercase text-accent-text" data-i18n={`orchestration.steps.${step.index}.kicker`}>{step.kicker}</p>
                        <h3 class="mt-2 font-display text-h3 text-ink" data-i18n={`orchestration.steps.${step.index}.title`}>{step.title}</h3>
                        <p class="mt-3 text-body-sm text-ink-muted" data-i18n={`orchestration.steps.${step.index}.body`}>{step.body}</p>
                      </div>
                    </div>
                  </li>
                ))
              }
            </ol>
          </div>
        </div>
      </section>

      <section id="features" class="bg-surface py-section lg:py-section-xl">
        <div class="container-page">
          <div class="grid gap-6 lg:grid-cols-[0.95fr_1.05fr] lg:items-end" data-reveal>
            <div>
              <p class="eyebrow" data-i18n="features.section_title">{copy.features.section_title}</p>
              <h2 class="section-heading" data-i18n="features.subtitle">{copy.features.subtitle}</h2>
            </div>
            <p class="section-copy" data-i18n="features.intro">{copy.features.intro}</p>
          </div>

          <div class="mt-12 grid gap-4 lg:grid-cols-12 lg:auto-rows-fr" data-reveal>
            <article class="panel bg-ink p-6 text-white lg:col-span-5 lg:row-span-2 lg:p-8">
              <p class="text-caption text-[#d8d2c7]" data-i18n="features.section_title">{copy.features.section_title}</p>
              <h3 class="mt-4 text-h2 text-white" data-i18n="features.hero.title">{copy.features.hero.title}</h3>
              <p class="mt-5 text-body text-[#d8d2c7]" data-i18n="features.hero.description">{copy.features.hero.description}</p>
              <ol class="mt-8 grid gap-3">
                {
                  copy.features.hero.sequence.map((item, index) => (
                    <li class="grid grid-cols-[auto_1fr] gap-3 rounded-card border border-white/10 bg-white/[0.04] p-3">
                      <span class="grid size-8 place-items-center rounded-control bg-accent text-caption text-accent-on">{index + 1}</span>
                      <span class="text-body-sm text-white" data-i18n={`features.hero.sequence.${index}`}>{item}</span>
                    </li>
                  ))
                }
              </ol>
            </article>
            {
              copy.features.cards.map((item, index) => (
                <article class={`panel p-6 transition duration-200 ease-expressive hover:-translate-y-0.5 hover:border-border-strong lg:p-7 ${featureCardSpans[index]}`}>
                  <p class="text-caption text-accent-text">{String(index + 1).padStart(2, '0')}</p>
                  <h3 class="mt-4 text-h4 text-ink" data-i18n={`features.cards.${index}.title`}>{item.title}</h3>
                  <p class="mt-3 text-body-sm text-ink-muted" data-i18n={`features.cards.${index}.description`}>{item.description}</p>
                </article>
              ))
            }
          </div>
        </div>
      </section>

      <section id="use-cases" class="border-y border-border bg-surface-muted py-section lg:py-section-lg">
        <div class="container-page grid gap-10 lg:grid-cols-[0.8fr_1.2fr] lg:items-start">
          <div data-reveal>
            <p class="eyebrow" data-i18n="use_cases.eyebrow">{copy.use_cases.eyebrow}</p>
            <h2 class="section-heading" data-i18n="use_cases.section_title">{copy.use_cases.section_title}</h2>
            <p class="section-copy" data-i18n="use_cases.section_subtitle">{copy.use_cases.section_subtitle}</p>
          </div>
          <div class="grid gap-4" data-reveal>
            {
              copy.use_cases.cases.map((item, index) => (
                <article class={`panel border-l-4 border-l-accent p-6 lg:p-8 ${index === 1 ? 'lg:ml-10' : index === 2 ? 'lg:ml-20' : ''}`}>
                  <p class="text-caption text-ink-muted">
                    <span data-i18n="use_cases.case_label">{copy.use_cases.case_label}</span> {index + 1}
                  </p>
                  <h3 class="mt-2 text-h3 text-ink" data-i18n={`use_cases.cases.${index}.title`}>{item.title}</h3>
                  <p class="mt-3 text-body text-ink-muted" data-i18n={`use_cases.cases.${index}.description`}>{item.description}</p>
                </article>
              ))
            }
          </div>
        </div>
      </section>

      <section class="bg-surface-raised py-section lg:py-section-lg">
        <div class="container-page grid gap-10 lg:grid-cols-[1fr_1.1fr] lg:items-center">
          <div data-reveal>
            <p class="eyebrow" data-i18n="trust.eyebrow">{copy.trust.eyebrow}</p>
            <h2 class="section-heading" data-i18n="trust.section_title">{copy.trust.section_title}</h2>
            <p class="mt-4 text-body-lg text-ink-muted" data-i18n="trust.description">{copy.trust.description}</p>
          </div>
          <div class="grid gap-4" data-reveal>
            <ol class="panel grid gap-0 overflow-hidden p-0" aria-label={copy.trust.section_title}>
              {
                copy.trust.proof_ledger.map((item, index) => (
                  <li class="grid gap-1 border-b border-border p-5 last:border-b-0 sm:grid-cols-[0.8fr_1fr] sm:items-center">
                    <p class="text-caption text-accent-text" data-i18n={`trust.proof_ledger.${index}.label`}>{item.label}</p>
                    <p class="text-body-sm font-bold text-ink" data-i18n={`trust.proof_ledger.${index}.value`}>{item.value}</p>
                  </li>
                ))
              }
            </ol>
            <ul class="grid gap-3 sm:grid-cols-4" aria-label="Azaman trust metrics">
              {
                copy.trust.metrics.map((metric, index) => (
                  <li class="rounded-card border border-border bg-surface p-5">
                    <p class="text-h3 text-ink" data-i18n={`trust.metrics.${index}.value`}>{metric.value}</p>
                    <p class="mt-1 text-body-sm text-ink-muted" data-i18n={`trust.metrics.${index}.label`}>{metric.label}</p>
                  </li>
                ))
              }
            </ul>
          </div>
        </div>
      </section>

      <section id="pricing" class="border-y border-border bg-surface py-section lg:py-section-lg">
        <div class="container-page">
          <div class="max-w-3xl" data-reveal>
            <p class="eyebrow" data-i18n="pricing_teaser.eyebrow">{copy.pricing_teaser.eyebrow}</p>
            <h2 class="section-heading" data-i18n="pricing_teaser.section_subtitle">{copy.pricing_teaser.section_subtitle}</h2>
          </div>
          <div class="mt-12 grid gap-4 lg:grid-cols-[0.85fr_1.15fr_0.85fr] lg:items-stretch" data-reveal>
            {
              copy.pricing_teaser.tiers.map((tier, index) => (
                <article class={`panel p-6 lg:p-8 ${tier.featured ? 'border-accent bg-accent-soft shadow-lift lg:-mt-6 lg:mb-6' : ''}`}>
                  <p class="text-caption text-ink-muted" data-i18n={`pricing_teaser.tiers.${index}.name`}>{tier.name}</p>
                  <div class="mt-3 flex items-end gap-1">
                    <p class="text-h2 text-ink" data-i18n={`pricing_teaser.tiers.${index}.price`}>{tier.price}</p>
                    <p class="pb-1 text-body-sm text-ink-muted" data-i18n={`pricing_teaser.tiers.${index}.unit`}>{tier.unit}</p>
                  </div>
                  <p class="mt-4 text-body-sm text-ink-muted" data-i18n={`pricing_teaser.tiers.${index}.description`}>{tier.description}</p>
                  <a href="mailto:hello@azaman.ai" class={`button mt-6 w-full ${tier.featured ? 'button-primary' : 'button-secondary'}`} data-i18n={`pricing_teaser.tiers.${index}.cta`}>
                    {tier.cta}
                  </a>
                </article>
              ))
            }
          </div>
        </div>
      </section>

      <section id="faq" class="bg-surface-raised py-section lg:py-section-lg">
        <div class="container-page">
          <div data-reveal>
            <p class="eyebrow" data-i18n="faq.section_title">{copy.faq.section_title}</p>
            <h2 class="section-heading" data-i18n="faq.subtitle">{copy.faq.subtitle}</h2>
          </div>
          <div class="mt-12 grid gap-4 lg:grid-cols-2" data-reveal>
            {
              copy.faq.items.map((item, index) => (
                <details class="panel group p-6 lg:p-8">
                  <summary class="flex cursor-pointer list-none items-center justify-between gap-4 text-left text-h4 text-ink">
                    <span data-i18n={`faq.items.${index}.question`}>{item.question}</span>
                    <span class="grid size-8 shrink-0 place-items-center rounded-control border border-border text-accent-text transition duration-200 ease-expressive group-open:rotate-45">
                      +
                    </span>
                  </summary>
                  <p class="mt-4 text-body-sm text-ink-muted" data-i18n={`faq.items.${index}.answer`}>{item.answer}</p>
                </details>
              ))
            }
          </div>
        </div>
      </section>
    </main>

    <footer class="bg-ink py-section text-surface">
      <div class="container-page">
        <div class="grid gap-10 border-b border-white/15 pb-10 lg:grid-cols-[1fr_0.9fr]">
          <div>
            <p class="eyebrow text-accent-soft">Azaman</p>
            <h2 class="mt-4 max-w-2xl text-h2" data-i18n="footer.cta_headline">{copy.footer.cta_headline}</h2>
            <p class="mt-4 max-w-xl text-body text-[#d8d2c7]" data-i18n="footer.cta_sub">{copy.footer.cta_sub}</p>
            <a href="mailto:hello@azaman.ai" class="button mt-8 border-surface-raised bg-surface-raised text-ink hover:bg-accent-soft" data-i18n="footer.cta_button">
              {copy.footer.cta_button}
            </a>
          </div>
          <div class="grid gap-8 sm:grid-cols-3">
            {footerGroups.map((group) => (
              <nav aria-label={`${group.heading} links`}>
                <p class="text-body-sm font-bold text-surface" data-i18n={`footer.secondary_nav.${group.key}.heading`}>{group.heading}</p>
                <ul class="mt-4 space-y-3">
                  {group.links.map((link) => (
                    <li>
                      <a href={link.href} class="text-body-sm text-[#d8d2c7] underline-offset-4 transition hover:text-white focus-visible:underline" data-i18n={link.key}>
                        {link.label}
                      </a>
                    </li>
                  ))}
                </ul>
              </nav>
            ))}
          </div>
        </div>
        <div class="flex flex-col gap-3 pt-8 text-body-sm text-[#d8d2c7] sm:flex-row sm:items-center sm:justify-between">
          <p data-i18n="footer.copyright">{copy.footer.copyright}</p>
          <p data-i18n="footer.brand_credit">{copy.footer.brand_credit}</p>
        </div>
      </div>
    </footer>

    <script>
      const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      const revealItems = Array.from(document.querySelectorAll('[data-reveal]'));
      const showStatic = () => {
        revealItems.forEach((item) => item.classList.add('is-visible'));
      };

      if (reduceMotion) {
        document.documentElement.classList.add('motion-reduced');
        showStatic();
      } else {
        document.documentElement.classList.add('motion-ready');
        const startMotion = async () => {
          const [{ default: gsap }, { default: ScrollTrigger }, { default: SplitText }, { default: CustomEase }] = await Promise.all([
            import('gsap'),
            import('gsap/ScrollTrigger'),
            import('gsap/SplitText'),
            import('gsap/CustomEase'),
          ]);

          gsap.registerPlugin(ScrollTrigger, SplitText, CustomEase);
          CustomEase.create('az-expressive', '0.2,0.8,0.2,1');
          CustomEase.create('az-signature', '0.16,1,0.3,1');
          CustomEase.create('az-gate', '0.65,0,0.35,1');

          const motion = {
            control: 0.16,
            panel: 0.22,
            reveal: 0.42,
            signature: 0.9,
            stagger: 0.07,
          };

          revealItems.forEach((item) => {
            gsap.fromTo(
              item,
              { y: 18 },
              {
                y: 0,
                duration: motion.reveal,
                ease: 'az-expressive',
                scrollTrigger: {
                  trigger: item,
                  start: 'top 86%',
                  once: true,
                },
              },
            );
          });

          const animateHeroTitle = () => {
            const title = document.querySelector('[data-split-title]');
            if (!title) return;
            try {
              const split = new SplitText(title, { type: 'words,lines', mask: 'lines' });
              gsap.from(split.words, {
                yPercent: 112,
                opacity: 0,
                duration: motion.signature,
                stagger: motion.stagger,
                ease: 'az-signature',
              });
            } catch {
              gsap.from(title, { y: 18, opacity: 0, duration: motion.signature, ease: 'az-signature' });
            }
          };

          if ('fonts' in document) {
            document.fonts.ready.then(animateHeroTitle);
          } else {
            animateHeroTitle();
          }

          gsap.to('[data-mesh-layer="one"]', { x: 34, y: -22, scale: 1.08, duration: 9, repeat: -1, yoyo: true, ease: 'sine.inOut' });
          gsap.to('[data-mesh-layer="two"]', { x: -28, y: 24, scale: 1.12, duration: 11, repeat: -1, yoyo: true, ease: 'sine.inOut' });
          gsap.to('[data-mesh-layer="three"]', { x: 18, y: 28, scale: 1.1, duration: 12, repeat: -1, yoyo: true, ease: 'sine.inOut' });
          gsap.to('[data-mesh-layer="four"]', { x: -36, y: -12, rotation: -10, duration: 13, repeat: -1, yoyo: true, ease: 'sine.inOut' });
          gsap.to('[data-mesh-layer="five"]', { x: 22, y: 18, scale: 1.18, duration: 8, repeat: -1, yoyo: true, ease: 'sine.inOut' });
          gsap.to('[data-agent-node]', {
            y: (index) => (index % 2 === 0 ? -8 : 8),
            duration: 3.6,
            stagger: 0.18,
            repeat: -1,
            yoyo: true,
            ease: 'sine.inOut',
          });
          gsap.fromTo(
            '[data-flow-line]',
            { strokeDasharray: 880, strokeDashoffset: 880 },
            { strokeDashoffset: 0, duration: motion.signature, ease: 'az-gate' },
          );

          const cards = gsap.utils.toArray('[data-orch-card]');
          if (cards.length) {
            gsap.set(cards, { y: 16 });
            gsap.set('[data-orch-line]', { scaleX: 0, transformOrigin: 'left center' });
            const orchestration = gsap.timeline({
              scrollTrigger: {
                trigger: '[data-orchestration]',
                start: 'top 76%',
                end: 'bottom 46%',
                scrub: 0.8,
              },
            });

            cards.forEach((card, index) => {
              orchestration
                .to(card, { y: 0, duration: motion.panel, ease: 'az-expressive' }, index * (motion.stagger * 4))
                .to('[data-orch-line]', { scaleX: (index + 1) / cards.length, duration: motion.signature, ease: 'az-gate' }, '<');
            });
          }

          window.addEventListener('load', () => ScrollTrigger.refresh(), { once: true });
        };

        const runMotion = () => {
          if ('requestIdleCallback' in window) {
            window.requestIdleCallback(startMotion, { timeout: 300 });
          } else {
            window.setTimeout(startMotion, 80);
          }
        };

        if (document.readyState === 'complete') {
          runMotion();
        } else {
          window.addEventListener('load', runMotion, { once: true });
        }
      }
    </script>
  </body>
</html>
