            </button>
          </form>
          <p id="lead-capture-mid-trust" class="form-lead-trust" data-i18n="lead_capture.trust_note">{copy.lead_capture.trust_note}</p>
          <p id="lead-capture-mid-status" class="form-lead-trust mt-2 hidden" role="status" aria-live="polite" data-lead-status></p>
        </div>
      </section>

      <section id="faq" class="bg-surface-raised py-section lg:py-section-lg">
        <div class="container-page">
          <div data-reveal>
            <p class="eyebrow" data-i18n="faq.section_title">{copy.faq.section_title}</p>
            <h2 class="section-heading" data-i18n="faq.subtitle">{copy.faq.subtitle}</h2>
          </div>
          <div class="mt-12 grid gap-4 lg:grid-cols-2" data-reveal>
            {
              copy.faq.items.map((item, index) => (
                <details class="panel group p-6 lg:p-8">
                  <summary class="flex cursor-pointer list-none items-center justify-between gap-4 text-left text-h4 text-ink">
                    <span data-i18n={`faq.items.${index}.question`}>{item.question}</span>
                    <span class="grid size-8 shrink-0 place-items-center rounded-control border border-border text-accent-text transition duration-200 ease-expressive group-open:rotate-45">
                      +
                    </span>
                  </summary>
                  <p class="mt-4 text-body-sm text-ink-muted" data-i18n={`faq.items.${index}.answer`}>{item.answer}</p>
                </details>
              ))
            }
          </div>
        </div>
      </section>
      <section class="manifesto-band">
        <div class="container-page max-w-3xl text-center">
          <div data-reveal>
            <p class="eyebrow" data-i18n="lead_capture.eyebrow">{copy.lead_capture.eyebrow}</p>
            <h2 class="section-heading mx-auto" data-i18n="lead_capture.headline">{copy.lead_capture.headline}</h2>
            <p class="section-copy mx-auto" data-i18n="lead_capture.sub">{copy.lead_capture.sub}</p>
          </div>
          <form
            class="form-lead mt-10 sm:justify-center"
            data-reveal
            data-lead-capture
            data-success={copy.lead_capture.success_message}
            data-error-invalid={copy.lead_capture.error_invalid}
            data-error-generic={copy.lead_capture.error_generic}
            aria-describedby="lead-capture-closer-trust lead-capture-closer-status"
            novalidate
          >
            <label class="sr-only" for="lead-email-closer" data-i18n="lead_capture.email_aria_label">{copy.lead_capture.email_aria_label}</label>
            <input
              id="lead-email-closer"
              type="email"
              name="email"
              class="input-lead sm:max-w-sm"
              placeholder={copy.lead_capture.email_placeholder}
              aria-label={copy.lead_capture.email_aria_label}
              autocomplete="email"
              required
              data-lead-input
            />
            <button
              type="submit"
              class="button button-primary min-h-12 px-6"
              aria-label={copy.lead_capture.submit_aria_label}
              data-i18n="lead_capture.submit_label"
            >
              {copy.lead_capture.submit_label}
            </button>
          </form>
          <p id="lead-capture-closer-trust" class="form-lead-trust mt-4" data-i18n="lead_capture.trust_note">{copy.lead_capture.trust_note}</p>
          <p id="lead-capture-closer-status" class="form-lead-trust mt-2 hidden" role="status" aria-live="polite" data-lead-status></p>
        </div>
      </section>
    </main>

    <footer class="bg-ink py-section text-surface">
      <div class="container-page">
        <div class="grid gap-10 border-b border-white/15 pb-10 lg:grid-cols-[1fr_0.9fr]">
          <div>
            <p class="eyebrow text-accent-soft">Azaman</p>
            <h2 class="mt-4 max-w-2xl text-h2" data-i18n="footer.cta_headline">{copy.footer.cta_headline}</h2>
            <p class="mt-4 max-w-xl text-body text-[#d8d2c7]" data-i18n="footer.cta_sub">{copy.footer.cta_sub}</p>
            <a href="#waitlist" class="button mt-8 border-surface-raised bg-surface-raised text-ink hover:bg-accent-soft" data-i18n="footer.cta_button">
              {copy.footer.cta_button}
            </a>
          </div>
          <div class="grid gap-8 sm:grid-cols-3">
            {footerGroups.map((group) => (
              <nav aria-label={`${group.heading} links`}>
                <p class="text-body-sm font-bold text-surface" data-i18n={`footer.secondary_nav.${group.key}.heading`}>{group.heading}</p>
                <ul class="mt-4 space-y-3">
                  {group.links.map((link) => (
                    <li>
                      <a href={link.href} class="text-body-sm text-[#d8d2c7] underline-offset-4 transition hover:text-white focus-visible:underline" data-i18n={link.key}>
                        {link.label}
                      </a>
                    </li>
                  ))}
                </ul>
              </nav>
            ))}
          </div>
        </div>
        <div class="flex flex-col gap-3 pt-8 text-body-sm text-[#d8d2c7] sm:flex-row sm:items-center sm:justify-between">
          <p data-i18n="footer.copyright">{copy.footer.copyright}</p>
          <p data-i18n="footer.brand_credit">{copy.footer.brand_credit}</p>
        </div>
      </div>
    </footer>

    <script>
      const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      const revealItems = Array.from(document.querySelectorAll('[data-reveal]'));
      const showStatic = () => {
        revealItems.forEach((item) => item.classList.add('is-visible'));
      };

      if (reduceMotion) {
        document.documentElement.classList.add('motion-reduced');
        showStatic();
      } else {
        document.documentElement.classList.add('motion-ready');
        document.documentElement.classList.add('reveal-ready');
        const startMotion = async () => {
          const [{ default: gsap }, { default: ScrollTrigger }, { default: SplitText }, { default: CustomEase }] = await Promise.all([
            import('gsap'),
            import('gsap/ScrollTrigger'),
            import('gsap/SplitText'),
            import('gsap/CustomEase'),
          ]);

          gsap.registerPlugin(ScrollTrigger, SplitText, CustomEase);
          CustomEase.create('az-expressive', '0.2,0.8,0.2,1');
          CustomEase.create('az-signature', '0.16,1,0.3,1');
          CustomEase.create('az-gate', '0.65,0,0.35,1');

          const motion = {
            control: 0.16,
            panel: 0.22,
            reveal: 0.42,
            signature: 0.9,
            stagger: 0.07,
          };

          revealItems.forEach((item) => {
            gsap.fromTo(
              item,
              { y: 18 },
              {
                y: 0,
                duration: motion.reveal,
                ease: 'az-expressive',
                scrollTrigger: {
                  trigger: item,
                  start: 'top 86%',
                  once: true,
                },
              },
            );
          });

          const animateHeroTitle = () => {
            const title = document.querySelector('[data-split-title]');
            if (!title) return;
            try {
              const split = new SplitText(title, { type: 'words,lines', mask: 'lines' });
              gsap.from(split.words, {
                yPercent: 112,
                opacity: 0,
                duration: motion.signature,
                stagger: motion.stagger,
                ease: 'az-signature',
              });
            } catch {
              gsap.from(title, { y: 18, opacity: 0, duration: motion.signature, ease: 'az-signature' });
            }
          };

          if ('fonts' in document) {
            document.fonts.ready.then(animateHeroTitle);
          } else {
            animateHeroTitle();
          }

          const meshTween = gsap.to('[data-mesh-layer]', {
            x: (i) => [34, -28, 18, -36, 22][i],
            y: (i) => [-22, 24, 28, -12, 18][i],
            scale: (i) => [1.08, 1.12, 1.1, 1, 1.18][i],
            rotation: (i) => [0, 0, 0, -10, 0][i],
            duration: 11,
            repeat: -1,
            yoyo: true,
            ease: 'sine.inOut',
          });
          ScrollTrigger.create({
            trigger: '.hero-section',
            start: 'top top',
            end: 'bottom top',
            onEnter: () => meshTween.play(),
            onLeave: () => meshTween.pause(),
            onEnterBack: () => meshTween.play(),
            onLeaveBack: () => meshTween.pause(),
          });
          gsap.to('[data-agent-node]', {
            y: (index) => (index % 2 === 0 ? -8 : 8),
            duration: 3.6,
            stagger: 0.18,
            repeat: -1,
            yoyo: true,
            ease: 'sine.inOut',
          });
          gsap.fromTo(
            '[data-flow-line]',
            { strokeDasharray: 880, strokeDashoffset: 880 },
            { strokeDashoffset: 0, duration: motion.signature, ease: 'az-gate' },
          );

          const cards = gsap.utils.toArray('[data-orch-card]');
          if (cards.length) {
            gsap.set(cards, { y: 16 });
            gsap.set('[data-orch-line]', { scaleX: 0, transformOrigin: 'left center' });
            const orchestration = gsap.timeline({
              scrollTrigger: {
                trigger: '[data-orchestration]',
                start: 'top 76%',
                end: 'bottom 46%',
                scrub: 0.8,
              },
            });

            cards.forEach((card, index) => {
              orchestration
                .to(card, { y: 0, duration: motion.panel, ease: 'az-expressive' }, index * (motion.stagger * 4))
                .to('[data-orch-line]', { scaleX: (index + 1) / cards.length, duration: motion.signature, ease: 'az-gate' }, '<');
            });
          }

          window.addEventListener('load', () => ScrollTrigger.refresh(), { once: true });
        };

        const runMotion = () => {
          if ('requestIdleCallback' in window) {
            window.requestIdleCallback(startMotion, { timeout: 300 });
          } else {
            window.setTimeout(startMotion, 80);
          }
        };

        if (document.readyState === 'complete') {
          runMotion();
        } else {
          window.addEventListener('load', runMotion, { once: true });
        }
      }
    </script>

    <script>
      const leadForms = document.querySelectorAll('[data-lead-capture]');
      const emailRe = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
      leadForms.forEach((form) => {
        const input = form.querySelector('[data-lead-input]');
        const status = form.parentElement?.querySelector('[data-lead-status]');
        const submit = form.querySelector('button[type="submit"]');
        if (!input || !status || !submit) return;
        const setStatus = (message, tone) => {
          status.textContent = message;
          status.classList.remove('hidden');
          status.dataset.tone = tone;
        };
        input.addEventListener('input', () => {
          if (input.getAttribute('aria-invalid') === 'true') {
            input.removeAttribute('aria-invalid');
            status.classList.add('hidden');
          }
        });
        form.addEventListener('submit', (event) => {
          event.preventDefault();
          const value = (input.value || '').trim();
          if (!emailRe.test(value)) {
            input.setAttribute('aria-invalid', 'true');
            setStatus(form.dataset.errorInvalid || 'Invalid email.', 'error');
            input.focus();
            return;
          }
          input.removeAttribute('aria-invalid');
          input.disabled = true;
          submit.disabled = true;
          setStatus(form.dataset.success || 'You’re on the list.', 'success');
        });
      });
    </script>
  </body>
</html>
